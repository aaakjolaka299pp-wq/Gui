function NapoleonGUI:AddSection(tab, name)
    local theme     = self.theme
    local page      = tab.page
    local order     = #tab._sections + 1
    local collapsed = false

    local wrapper = create("Frame", {
        Name              = "Section_" .. name,
        Size              = UDim2.new(1, 0, 0, 0),
        AutomaticSize     = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        LayoutOrder       = order,
    })
    wrapper.Parent = page
    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = wrapper

    -- Section header: slightly lighter than body, accent left bar + accent text
    local header = create("TextButton", {
        Text             = "",
        Size             = UDim2.new(1, 0, 0, 34),
        BackgroundColor3 = theme.sectionBg,
        BackgroundTransparency = 0,
        BorderSizePixel  = 0,
        LayoutOrder      = 0,
    })
    header.Parent = wrapper

    -- Left color bar
    create("Frame", {
        Size             = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = theme.accent,
        BorderSizePixel  = 0,
    }).Parent = header

    -- Section title text
    create("TextLabel", {
        Text      = name,
        Size      = UDim2.new(1, -36, 1, 0),
        Position  = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = theme.accent,
        TextXAlignment = Enum.TextXAlignment.Left,
        Font      = Enum.Font.GothamBold,
        TextSize  = 12,
    }).Parent = header

    local chevron = create("TextLabel", {
        Text      = "∨",
        Size      = UDim2.new(0, 18, 1, 0),
        Position  = UDim2.new(1, -22, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = theme.accent,
        Font      = Enum.Font.GothamBold,
        TextSize  = 12,
    })
    chevron.Parent = header

    local body = create("Frame", {
        Name              = "SectionBody",
        Size              = UDim2.new(1, 0, 0, 0),
        AutomaticSize     = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        LayoutOrder       = 1,
    })
    body.Parent = wrapper
    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = body

    header.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        body.Visible = not collapsed
        chevron.Text = collapsed and ">" or "∨"
    end)

    local section = {
        wrapper = wrapper,
        body    = body,
        _order  = 0,
        _gui    = self,
        _tab    = tab,
    }
    table.insert(tab._sections, section)
    return section
end

-- ══════════════════════════════════════════════════════════════
--  ELEMENTS
-- ══════════════════════════════════════════════════════════════

local function makeRow(section, h)
    h = h or 38
    local theme = section._gui.theme
    section._order = section._order + 1
    local row = create("Frame", {
        Size            = UDim2.new(1, 0, 0, h),
        BackgroundColor3 = theme.rowBg,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        LayoutOrder     = section._order,
    })
    row.Parent = section.body
    -- bottom separator
    create("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.95,
        BorderSizePixel  = 0,
    }).Parent = row
    return row, theme
end

-- TOGGLE
function NapoleonGUI:AddToggle(section, opts)
    opts = opts or {}
    local flag     = opts.Flag    or opts.Name or "toggle_" .. math.random(9999)
    local default  = opts.Default ~= nil and opts.Default or false
    local callback = opts.Callback or function() end

    self._flags[flag] = default

    local row, theme = makeRow(section)

    create("TextLabel", {
        Text      = opts.Name or "Toggle",
        Size      = UDim2.new(0.72, 0, 1, 0),
        Position  = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(200, 200, 220),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font      = Enum.Font.Gotham,
        TextSize  = 12,
    }).Parent = row

    local track = create("TextButton", {
        Text     = "",
        Size     = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -52, 0.5, -10),
        BackgroundColor3 = default and theme.accent or Color3.fromRGB(28, 28, 46),
        BorderSizePixel  = 0,
    }, { makeCorner(10) })
    track.Parent = row

    local knob = create("Frame", {
        Size     = UDim2.new(0, 14, 0, 14),
        Position = default and UDim2.new(0, 23, 0.5, -7) or UDim2.new(0, 3, 0.5, -7),
        BackgroundColor3 = default and Color3.fromRGB(255,255,255) or Color3.fromRGB(70,70,90),
        BorderSizePixel  = 0,
    }, { makeCorner(99) })
    knob.Parent = track

    local state = default
    track.MouseButton1Click:Connect(function()
        state = not state
        self._flags[flag] = state
        tween(track, { BackgroundColor3 = state and theme.accent or Color3.fromRGB(28,28,46) }, 0.2)
        tween(knob, {
            Position         = state and UDim2.new(0,23,0.5,-7) or UDim2.new(0,3,0.5,-7),
            BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(70,70,90),
        }, 0.2, Enum.EasingStyle.Back)
        pcall(callback, state)
    end)

    return {
        Set = function(v)
            state = v; self._flags[flag] = v
            tween(track, { BackgroundColor3 = v and theme.accent or Color3.fromRGB(28,28,46) }, 0.15)
            tween(knob, { Position = v and UDim2.new(0,23,0.5,-7) or UDim2.new(0,3,0.5,-7) }, 0.15)
            pcall(callback, v)
        end,
        Get = function() return state end,
    }
end

-- SLIDER
function NapoleonGUI:AddSlider(section, opts)
    opts = opts or {}
    local flag     = opts.Flag    or opts.Name or "slider_" .. math.random(9999)
    local min      = opts.Min     or 0
    local max      = opts.Max     or 100
    local default  = opts.Default or min
    local suffix   = opts.Suffix  or ""
    local callback = opts.Callback or function() end

    self._flags[flag] = default

    local row, theme = makeRow(section, 52)
    local val = default

    create("TextLabel", {
        Text     = opts.Name or "Slider",
        Size     = UDim2.new(0.6, 0, 0, 22),
        Position = UDim2.new(0, 16, 0, 7),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(200,200,220),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 12,
    }).Parent = row

    local valLabel = create("TextLabel", {
        Text     = tostring(default) .. suffix,
        Size     = UDim2.new(0.4, -16, 0, 22),
        Position = UDim2.new(0.6, 0, 0, 7),
        BackgroundTransparency = 1,
        TextColor3 = theme.accent,
        TextXAlignment = Enum.TextXAlignment.Right,
        Font     = Enum.Font.GothamBold,
        TextSize = 12,
    })
    valLabel.Parent = row

    local track = create("Frame", {
        Size     = UDim2.new(1, -32, 0, 4),
        Position = UDim2.new(0, 16, 0, 36),
        BackgroundColor3 = Color3.fromRGB(25, 25, 45),
        BorderSizePixel  = 0,
    }, { makeCorner(2) })
    track.Parent = row

    local fill = create("Frame", {
        Size             = UDim2.new((default-min)/(max-min), 0, 1, 0),
        BackgroundColor3 = theme.accent,
        BorderSizePixel  = 0,
    }, { makeCorner(2) })
    fill.Parent = track

    local handle = create("Frame", {
        Size     = UDim2.new(0, 10, 0, 10),
        Position = UDim2.new((default-min)/(max-min), -5, 0.5, -5),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel  = 0,
    }, { makeCorner(99) })
    handle.Parent = track

    local sliding = false
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = true end
    end)
    track.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local pct = math.clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            val = math.floor(min + (max - min) * pct)
            self._flags[flag] = val
            fill.Size = UDim2.new(pct, 0, 1, 0)
            handle.Position = UDim2.new(pct, -5, 0.5, -5)
            valLabel.Text = tostring(val) .. suffix
            pcall(callback, val)
        end
    end)

    return {
        Set = function(v)
            v = math.clamp(v, min, max); val = v; self._flags[flag] = v
            local pct = (v-min)/(max-min)
            fill.Size = UDim2.new(pct,0,1,0); handle.Position = UDim2.new(pct,-5,0.5,-5)
            valLabel.Text = tostring(v) .. suffix; pcall(callback, v)
        end,
        Get = function() return val end,
    }
end

-- BUTTON (full-width with icon cursor matching reference)
function NapoleonGUI:AddButton(section, opts)
    opts = opts or {}
    local callback = opts.Callback or function() end
    local row, theme = makeRow(section, 38)

    -- Left mouse icon area (matches reference screenshot style)
    local iconBox = create("Frame", {
        Size             = UDim2.new(0, 22, 0, 22),
        Position         = UDim2.new(1, -32, 0.5, -11),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 0.88,
        BorderSizePixel  = 0,
    }, { makeCorner(4) })
    iconBox.Parent = row

    create("TextLabel", {
        Text      = "🖱",
        Size      = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        TextColor3 = theme.accent,
        Font      = Enum.Font.Gotham,
        TextSize  = 11,
    }).Parent = iconBox

    local btn = create("TextButton", {
        Text     = opts.Name or "Button",
        Size     = UDim2.new(1, 0, 1, -1),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(200,200,220),
        Font      = Enum.Font.Gotham,
        TextSize  = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        BorderSizePixel = 0,
    })
    btn.Parent = row

    -- Indent text
    create("UIPadding", { PaddingLeft = UDim.new(0, 16) }).Parent = btn

    btn.MouseEnter:Connect(function()
        tween(row, { BackgroundColor3 = theme.accent }, 0.12)
        row.BackgroundTransparency = 0.92
    end)
    btn.MouseLeave:Connect(function()
        tween(row, { BackgroundColor3 = section._gui.theme.rowBg }, 0.12)
        row.BackgroundTransparency = 0
    end)
    btn.MouseButton1Click:Connect(function()
        row.BackgroundTransparency = 0.85
        task.delay(0.15, function() row.BackgroundTransparency = 0 end)
        pcall(callback)
    end)

    return btn
end

-- DUAL BUTTON (two side-by-side buttons like Save/Load, Delete/Copy in reference)
function NapoleonGUI:AddDualButton(section, opts1, opts2)
    opts1 = opts1 or {}; opts2 = opts2 or {}
    local theme = section._gui.theme
    section._order = section._order + 1
    local row = create("Frame", {
        Size            = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder     = section._order,
    })
    row.Parent = section.body

    local function makeHalfBtn(name, xScale, callback)
        local bg = create("Frame", {
            Size             = UDim2.new(0.5, -1, 1, -1),
            Position         = UDim2.new(xScale, xScale > 0 and 1 or 0, 0, 0),
            BackgroundColor3 = theme.rowBg,
            BorderSizePixel  = 0,
        })
        bg.Parent = row

        local iconBox = create("Frame", {
            Size             = UDim2.new(0, 20, 0, 20),
            Position         = UDim2.new(1, -26, 0.5, -10),
            BackgroundColor3 = theme.accent,
            BackgroundTransparency = 0.88,
            BorderSizePixel  = 0,
        }, { makeCorner(4) })
        iconBox.Parent = bg

        create("TextLabel", {
            Text      = "🖱",
            Size      = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            TextColor3 = theme.accent,
            Font      = Enum.Font.Gotham,
            TextSize  = 10,
        }).Parent = iconBox

        local btn = create("TextButton", {
            Text     = name,
            Size     = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            TextColor3 = Color3.fromRGB(200,200,220),
            Font      = Enum.Font.Gotham,
            TextSize  = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            BorderSizePixel = 0,
        })
        btn.Parent = bg
        create("UIPadding", { PaddingLeft = UDim.new(0, 14) }).Parent = btn

        btn.MouseEnter:Connect(function() tween(bg, { BackgroundColor3 = theme.accent }, 0.12); bg.BackgroundTransparency = 0.9 end)
        btn.MouseLeave:Connect(function() tween(bg, { BackgroundColor3 = theme.rowBg }, 0.12); bg.BackgroundTransparency = 0 end)
        btn.MouseButton1Click:Connect(function() pcall(callback or function() end) end)
        return btn
    end

    makeHalfBtn(opts1.Name or "Button 1", 0, opts1.Callback)
    makeHalfBtn(opts2.Name or "Button 2", 0.5, opts2.Callback)

    -- divider between halves
    create("Frame", {
        Size             = UDim2.new(0, 1, 1, 0),
        Position         = UDim2.new(0.5, 0, 0, 0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.94,
        BorderSizePixel  = 0,
    }).Parent = row

    -- bottom separator
    create("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.95,
        BorderSizePixel  = 0,
    }).Parent = row
end

