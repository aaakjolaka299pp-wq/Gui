-- ══════════════════════════════════════════════════════════════
--  SET THEME
-- ══════════════════════════════════════════════════════════════
function NapoleonGUI:SetTheme(name)
    local T=THEMES[name]; if not T then return end
    self.themeName=name; self.theme=T
    tween(self._main,{BackgroundColor3=hex(T.body)},0.3)
    tween(self._sidebar,{BackgroundColor3=hex(T.sidebar)},0.3)
    tween(self._bar,{BackgroundColor3=hex(T.bar)},0.3)
    self._slash.TextColor3=hex(T.accent)
    if self._bigN then tween(self._bigN,{TextColor3=hex(T.accent)},0.3) end
    if self._gL then
        tween(self._gL,{BackgroundColor3=hex(T.body)},0.3)
        tween(self._gB,{BackgroundColor3=hex(T.body)},0.3)
        tween(self._gT,{BackgroundColor3=hex(T.body)},0.3)
    end
    -- Re-tint active tab indicator
    if self._activeTab then
        self._activeTab.lbl.TextColor3=hex(T.accent)
        self._activeTab.ind.BackgroundColor3=hex(T.accent)
    end
end

function NapoleonGUI:GetFlag(k) return self._flags[k] end
NapoleonGUI.Themes = THEMES

return NapoleonGUI

