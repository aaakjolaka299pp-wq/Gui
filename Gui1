        tween(track, { BackgroundColor3 = state and theme.accent or Color3.fromRGB(30,30,48) }, 0.2)
        tween(knob,  {
            Position   = state and UDim2.new(0,25,0.5,-7) or UDim2.new(0,4,0.5,-7),
            BackgroundColor3 = state and Color3.fromRGB(255,255,255) or Color3.fromRGB(80,80,80),
        }, 0.2, Enum.EasingStyle.Back)
        pcall(callback, state)
