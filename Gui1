-- ══════════════════════════════════════════════════════════════
function NapoleonGUI:AddSlider(sec, opts)
    opts=opts or {}
    local flag=opts.Flag or opts.Name or "sl_"..math.random(9999)
    local mn,mx,def,sfx,cb = opts.Min or 0, opts.Max or 100, opts.Default or (opts.Min or 0), opts.Suffix or "", opts.Callback or function()end
    self._flags[flag]=def
    local row,T=mkRow(sec,50); local val=def

    create("TextLabel",{Text=opts.Name or "Slider",Size=UDim2.new(0.65,0,0,20),Position=UDim2.new(0,14,0,7),BackgroundTransparency=1,TextColor3=hex(T.text),TextXAlignment=Enum.TextXAlignment.Left,Font=Enum.Font.Gotham,TextSize=12}).Parent=row
    local vLbl=create("TextLabel",{Text=tostring(def)..sfx,Size=UDim2.new(0.35,-14,0,20),Position=UDim2.new(0.65,0,0,7),BackgroundTransparency=1,TextColor3=hex(T.accent),TextXAlignment=Enum.TextXAlignment.Right,Font=Enum.Font.GothamBold,TextSize=12})
    vLbl.Parent=row

    local trk=create("Frame",{Size=UDim2.new(1,-28,0,4),Position=UDim2.new(0,14,0,34),BackgroundColor3=Color3.fromRGB(22,22,40),BorderSizePixel=0},{corner(2)})
    trk.Parent=row
    local fill=create("Frame",{Size=UDim2.new((def-mn)/(mx-mn),0,1,0),BackgroundColor3=hex(T.accent),BorderSizePixel=0},{corner(2)})
    fill.Parent=trk
    local knob=create("Frame",{Size=UDim2.new(0,10,0,10),Position=UDim2.new((def-mn)/(mx-mn),-5,0.5,-5),BackgroundColor3=Color3.new(1,1,1),BorderSizePixel=0},{corner(99)})
    knob.Parent=trk

    local sl=false
    trk.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=true end end)
    trk.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sl=false end end)
    UserInputService.InputChanged:Connect(function(i)
        if sl and i.UserInputType==Enum.UserInputType.MouseMovement then
            local p=math.clamp((i.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
            val=math.floor(mn+(mx-mn)*p); self._flags[flag]=val
            fill.Size=UDim2.new(p,0,1,0); knob.Position=UDim2.new(p,-5,0.5,-5)
            vLbl.Text=tostring(val)..sfx; pcall(cb,val)
        end
    end)
    return {Set=function(v) v=math.clamp(v,mn,mx);val=v;self._flags[flag]=v;local p=(v-mn)/(mx-mn);fill.Size=UDim2.new(p,0,1,0);knob.Position=UDim2.new(p,-5,0.5,-5);vLbl.Text=tostring(v)..sfx end,Get=function()return val end}
end

