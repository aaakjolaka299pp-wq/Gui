--  THEME CHANGER
-- ══════════════════════════════════════════════════════════════
function NapoleonGUI:SetTheme(name)
    local t = THEMES[name]
    if not t then return end
    self.themeName = name
    self.theme     = t
    tween(self._main, { BackgroundColor3 = t.body }, 0.3)
    self._badgeLabel.Text = name:upper()
    tween(self._badgeLabel, { TextColor3 = t.accent }, 0.2)
    if self._bigN then
        tween(self._bigN, { TextColor3 = t.accent }, 0.3)
    end
    if self._gradLeft then
        tween(self._gradLeft,   { BackgroundColor3 = t.body }, 0.3)
        tween(self._gradBottom, { BackgroundColor3 = t.body }, 0.3)
        tween(self._gradTop,    { BackgroundColor3 = t.body }, 0.3)
    end
end

