-- SLIDER
function NapoleonGUI:AddSlider(section, opts)
    opts = opts or {}
    local flag     = opts.Flag or opts.Name or "slider_" .. math.random(9999)
    local min      = opts.Min      or 0
    local max      = opts.Max      or 100
    local default  = opts.Default  or min
    local suffix   = opts.Suffix   or ""
    local callback = opts.Callback or function() end

    self._flags[flag] = default

    local row, theme = makeRow(section, 50)
    local val = default

    -- Label row
    create("TextLabel", {
        Text     = opts.Name or "Slider",
        Size     = UDim2.new(0.6, 0, 0, 20),
        Position = UDim2.new(0, 14, 0, 6),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(208,208,232),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 12,
    }).Parent = row

    local valLabel = create("TextLabel", {
        Text     = tostring(default) .. suffix,
        Size     = UDim2.new(0.4, -14, 0, 20),
        Position = UDim2.new(0.6, 0, 0, 6),
        BackgroundTransparency = 1,
        TextColor3 = theme.accent,
        TextXAlignment = Enum.TextXAlignment.Right,
        Font     = Enum.Font.GothamBold,
        TextSize = 12,
    })
    valLabel.Parent = row

    -- Track
    local track = create("Frame", {
        Size     = UDim2.new(1, -28, 0, 4),
        Position = UDim2.new(0, 14, 0, 34),
        BackgroundColor3 = Color3.fromRGB(30,30,50),
        BorderSizePixel = 0,
    }, { makeCorner(2) })
    track.Parent = row

    local fill = create("Frame", {
        Size     = UDim2.new((default-min)/(max-min), 0, 1, 0),
        BackgroundColor3 = theme.accent,
        BorderSizePixel = 0,
    }, { makeCorner(2) })
    fill.Parent = track

    local handle = create("Frame", {
        Size     = UDim2.new(0, 10, 0, 10),
        Position = UDim2.new((default-min)/(max-min), -5, 0.5, -5),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0,
    }, { makeCorner(99) })
    handle.Parent = track

    local sliding = false
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
        end
    end)
    track.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local absPos  = track.AbsolutePosition.X
            local absSize = track.AbsoluteSize.X
            local pct     = math.clamp((inp.Position.X - absPos) / absSize, 0, 1)
            val           = math.floor(min + (max - min) * pct)
            self._flags[flag] = val
            fill.Size   = UDim2.new(pct, 0, 1, 0)
            handle.Position = UDim2.new(pct, -5, 0.5, -5)
            valLabel.Text = tostring(val) .. suffix
            pcall(callback, val)
        end
    end)

    return {
        Set = function(v)
            v   = math.clamp(v, min, max)
            val = v
            self._flags[flag] = v
            local pct = (v-min)/(max-min)
            fill.Size   = UDim2.new(pct, 0, 1, 0)
            handle.Position = UDim2.new(pct, -5, 0.5, -5)
            valLabel.Text = tostring(v) .. suffix
            pcall(callback, v)
        end,
        Get = function() return val end,
    }
end

