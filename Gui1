function NapoleonGUI:AddTab(name)
    local theme    = self.theme
    local tabIndex = #self._tabs + 1

    local btn = create("TextButton", {
        Text                   = "",
        Size                   = UDim2.new(1, 0, 0, 40),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        LayoutOrder            = tabIndex,
    })
    btn.Parent = self._tabList

    -- Active indicator bar on left
    local indicator = create("Frame", {
        Size             = UDim2.new(0, 3, 0.65, 0),
        Position         = UDim2.new(0, 0, 0.175, 0),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 1,
        BorderSizePixel  = 0,
    }, { makeCorner(2) })
    indicator.Parent = btn

    local label = create("TextLabel", {
        Text      = name,
        Size      = UDim2.new(1, -18, 1, 0),
        Position  = UDim2.new(0, 18, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(75, 75, 100),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font      = Enum.Font.Gotham,
        TextSize  = 13,
    })
    label.Parent = btn

    local page = create("ScrollingFrame", {
        Name                   = "Page_" .. name,
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel        = 0,
        ScrollBarThickness     = 3,
        ScrollBarImageColor3   = theme.accent,
        CanvasSize             = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize    = Enum.AutomaticSize.Y,
        Visible                = false,
    })
    page.Parent = self._content
    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,0) }).Parent = page

    local tab = {
        name      = name,
        btn       = btn,
        indicator = indicator,
        label     = label,
        page      = page,
        _sections = {},
        _gui      = self,
    }
    setmetatable(tab, { __index = NapoleonGUI })
    tab._flags = self._flags

    table.insert(self._tabs, tab)

    btn.MouseEnter:Connect(function()
        if self._activeTab ~= tab then
            tween(label, { TextColor3 = Color3.fromRGB(160, 160, 190) }, 0.12)
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activeTab ~= tab then
            tween(label, { TextColor3 = Color3.fromRGB(75, 75, 100) }, 0.12)
        end
    end)
    btn.MouseButton1Click:Connect(function() self:_selectTab(tab) end)

    if tabIndex == 1 then self:_selectTab(tab) end

    return tab
end

function NapoleonGUI:_selectTab(tab)
    if self._activeTab then
        local old = self._activeTab
        tween(old.indicator, { BackgroundTransparency = 1 }, 0.15)
        tween(old.label, { TextColor3 = Color3.fromRGB(75,75,100), Font = Enum.Font.Gotham }, 0.15)
        old.btn.BackgroundTransparency = 1
        old.page.Visible = false
    end
    self._activeTab = tab
    tween(tab.indicator, { BackgroundTransparency = 0 }, 0.15)
    tween(tab.label, { TextColor3 = self.theme.accent }, 0.15)
    tab.label.Font = Enum.Font.GothamBold
    tab.btn.BackgroundColor3 = self.theme.accent
    tab.btn.BackgroundTransparency = 0.9
    tab.page.Visible = true
end

