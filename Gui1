    create("TextLabel",{Text=opts.Name or "Dropdown",Size=UDim2.new(1,-46,0,20),Position=UDim2.new(0,14,0,5),BackgroundTransparency=1,TextColor3=hex(T.text),TextXAlignment=Enum.TextXAlignment.Left,Font=Enum.Font.Gotham,TextSize=13}).Parent=row
    create("TextLabel",{Text=ph,Size=UDim2.new(1,-46,0,16),Position=UDim2.new(0,14,0,27),BackgroundTransparency=1,TextColor3=hex(T.subtext),TextXAlignment=Enum.TextXAlignment.Left,Font=Enum.Font.Gotham,TextSize=10}).Parent=row

    -- Value shown (short) + chevron
    local valLbl=create("TextLabel",{Text=sel~="" and sel or "",Size=UDim2.new(0,80,0,20),Position=UDim2.new(1,-124,0.5,-10),BackgroundTransparency=1,TextColor3=hex(T.accent),TextXAlignment=Enum.TextXAlignment.Right,Font=Enum.Font.GothamBold,TextSize=11})
    valLbl.Parent=row

    local chevBtn=create("TextButton",{Text="∨",Size=UDim2.new(0,26,0,26),Position=UDim2.new(1,-36,0.5,-13),BackgroundColor3=hex(T.accent),BackgroundTransparency=0.85,TextColor3=hex(T.accent),Font=Enum.Font.GothamBold,TextSize=13,BorderSizePixel=0},{corner(5)})
    chevBtn.Parent=row

    -- Floating dropdown panel (positioned to RIGHT of the row, matches ref)
    local panelW = 160
    local panelH = math.min(#items,5)*30+38
    local panel=create("Frame",{
        Size=UDim2.new(0,panelW,0,panelH),
        Position=UDim2.new(1,4,0,0),
        BackgroundColor3=Color3.fromRGB(10,10,20),
        BorderSizePixel=0, ZIndex=20, Visible=false,
    },{corner(7),stroke(hex(T.accent),1,0.55)})
    panel.Parent=row

    -- Search bar
    local searchBg=create("Frame",{Size=UDim2.new(1,-8,0,26),Position=UDim2.new(0,4,0,5),BackgroundColor3=Color3.fromRGB(18,18,32),BorderSizePixel=0,ZIndex=21},{corner(5)})
    searchBg.Parent=panel
    local searchBox=create("TextBox",{Text="",PlaceholderText="Search",Size=UDim2.new(1,-10,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,TextColor3=Color3.fromRGB(200,200,220),PlaceholderColor3=Color3.fromRGB(60,60,85),TextXAlignment=Enum.TextXAlignment.Left,Font=Enum.Font.Gotham,TextSize=11,ClearTextOnFocus=false,BorderSizePixel=0,ZIndex=22})
    searchBox.Parent=searchBg

    local itemsCon=create("ScrollingFrame",{Size=UDim2.new(1,0,1,-38),Position=UDim2.new(0,0,0,38),BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=2,ScrollBarImageColor3=hex(T.accent),CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,ZIndex=21})
    itemsCon.Parent=panel
    list(nil,0).Parent=itemsCon

    local entries={}
    for i,item in ipairs(items) do
        local iBtn=create("TextButton",{Text=item,Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,TextColor3=item==sel and hex(T.accent) or Color3.fromRGB(170,170,195),TextXAlignment=Enum.TextXAlignment.Left,Font=Enum.Font.Gotham,TextSize=12,LayoutOrder=i,ZIndex=21,BorderSizePixel=0})
        pad(12).Parent=iBtn
        local selBar=create("Frame",{Size=UDim2.new(0,3,0.55,0),Position=UDim2.new(0,0,0.225,0),BackgroundColor3=hex(T.accent),BackgroundTransparency=item==sel and 0 or 1,BorderSizePixel=0,ZIndex=22},{corner(2)})
        selBar.Parent=iBtn
        iBtn.Parent=itemsCon
        iBtn.MouseEnter:Connect(function() iBtn.BackgroundColor3=hex(T.accent); tween(iBtn,{BackgroundTransparency=0.9},0.08) end)
        iBtn.MouseLeave:Connect(function() tween(iBtn,{BackgroundTransparency=1},0.08) end)
        iBtn.MouseButton1Click:Connect(function()
            for _,e in ipairs(entries) do e.b.TextColor3=Color3.fromRGB(170,170,195); e.s.BackgroundTransparency=1 end
            sel=item; self._flags[flag]=item; valLbl.Text=item
            iBtn.TextColor3=hex(T.accent); selBar.BackgroundTransparency=0
            panel.Visible=false; open=false; pcall(cb,item)
        end)
        table.insert(entries,{b=iBtn,s=selBar,name=item})
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q=searchBox.Text:lower()
        for _,e in ipairs(entries) do e.b.Visible=e.name:lower():find(q,1,true)~=nil end
    end)

    chevBtn.MouseButton1Click:Connect(function()
        open=not open; panel.Visible=open
        if open then searchBox.Text="" end
        chevBtn.Text=open and "∧" or "∨"
    end)

    return {
        Set=function(v) sel=v;self._flags[flag]=v;valLbl.Text=v;pcall(cb,v) end,
        Get=function()return sel end,
    }
end

