function NapoleonGUI:AddTextBox(section, opts)
    opts = opts or {}
    local flag     = opts.Flag    or opts.Name or "tb_" .. math.random(9999)
    local callback = opts.Callback or function() end

    self._flags[flag] = opts.Default or ""

    local row, theme = makeRow(section, 44)

    create("TextLabel", {
        Text     = opts.Name or "Input",
        Size     = UDim2.new(1, -14, 0, 18),
        Position = UDim2.new(0, 14, 0, 4),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(208,208,232),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 12,
    }).Parent = row

    local box = create("TextBox", {
        Text              = opts.Default or "",
        PlaceholderText   = opts.Placeholder or "Type here...",
        Size              = UDim2.new(1, -28, 0, 20),
        Position          = UDim2.new(0, 14, 0, 22),
        BackgroundTransparency = 1,
        TextColor3        = Color3.fromRGB(200,200,220),
        PlaceholderColor3 = Color3.fromRGB(80,80,100),
        TextXAlignment    = Enum.TextXAlignment.Left,
        Font              = Enum.Font.Gotham,
        TextSize          = 12,
        ClearTextOnFocus  = false,
        BorderSizePixel   = 0,
    })
    box.Parent = row

    local underline = create("Frame", {
        Size     = UDim2.new(1, -28, 0, 1),
        Position = UDim2.new(0, 14, 1, -3),
        BackgroundColor3 = Color3.fromRGB(50, 50, 90),
        BorderSizePixel = 0,
    })
    underline.Parent = row

    box.Focused:Connect(function()
        tween(underline, { BackgroundColor3 = theme.accent }, 0.18)
    end)
    box.FocusLost:Connect(function(enter)
        tween(underline, { BackgroundColor3 = Color3.fromRGB(50,50,90) }, 0.18)
        self._flags[flag] = box.Text
        if enter then pcall(callback, box.Text) end
    end)

    return {
        Set = function(v) box.Text = v; self._flags[flag] = v end,
        Get = function() return box.Text end,
    }
end

