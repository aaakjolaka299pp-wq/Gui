-- DROPDOWN  (styled like reference: name on left, value button with ▾ on right)
function NapoleonGUI:AddDropdown(section, opts)
    opts = opts or {}
    local flag     = opts.Flag    or opts.Name or "dd_" .. math.random(9999)
    local items    = opts.Items   or {}
    local default  = opts.Default or (items[1] or "")
    local callback = opts.Callback or function() end
    local placeholder = opts.Placeholder or "Select the " .. (opts.Name or "option") .. " you want"

    self._flags[flag] = default

    local row, theme = makeRow(section, 52)
    local selected = default
    local open     = false

    -- Label + description rows
    create("TextLabel", {
        Text     = opts.Name or "Dropdown",
        Size     = UDim2.new(1, -48, 0, 20),
        Position = UDim2.new(0, 16, 0, 5),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(200,200,220),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 13,
    }).Parent = row

    create("TextLabel", {
        Text     = placeholder,
        Size     = UDim2.new(1, -48, 0, 16),
        Position = UDim2.new(0, 16, 0, 26),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(75, 75, 100),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 10,
    }).Parent = row

    -- Right chevron button
    local valBtn = create("TextButton", {
        Text     = "∨",
        Size     = UDim2.new(0, 28, 0, 28),
        Position = UDim2.new(1, -38, 0.5, -14),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 0.85,
        TextColor3 = theme.accent,
        Font     = Enum.Font.GothamBold,
        TextSize = 14,
        BorderSizePixel = 0,
    }, { makeCorner(5) })
    valBtn.Parent = row

    -- Current value indicator
    local valLabel = create("TextLabel", {
        Text     = selected ~= "" and selected or "",
        Size     = UDim2.new(0, 100, 0, 20),
        Position = UDim2.new(1, -148, 0.5, -10),
        BackgroundTransparency = 1,
        TextColor3 = theme.accent,
        TextXAlignment = Enum.TextXAlignment.Right,
        Font     = Enum.Font.GothamBold,
        TextSize = 11,
    })
    valLabel.Parent = row

    -- Dropdown panel (floating, matches reference style with search)
    local listFrame = create("Frame", {
        Size     = UDim2.new(0, 155, 0, math.min(#items, 5) * 30 + 38),
        Position = UDim2.new(1, -165, 0, 52),
        BackgroundColor3 = Color3.fromRGB(12, 12, 22),
        BorderSizePixel  = 0,
        ZIndex   = 20,
        Visible  = false,
    }, { makeCorner(7), makeStroke(theme.accent, 1, 0.6) })
    listFrame.Parent = row

    -- Search box at top
    local searchBox = create("TextBox", {
        Text              = "",
        PlaceholderText   = "Search",
        Size              = UDim2.new(1, -12, 0, 28),
        Position          = UDim2.new(0, 6, 0, 5),
        BackgroundColor3  = Color3.fromRGB(18, 18, 32),
        BackgroundTransparency = 0,
        TextColor3        = Color3.fromRGB(200,200,220),
        PlaceholderColor3 = Color3.fromRGB(70,70,90),
        TextXAlignment    = Enum.TextXAlignment.Left,
        Font              = Enum.Font.Gotham,
        TextSize          = 11,
        ClearTextOnFocus  = false,
        BorderSizePixel   = 0,
        ZIndex            = 21,
    }, { makeCorner(5) })
    searchBox.Parent = listFrame
    create("UIPadding", { PaddingLeft = UDim.new(0, 8) }).Parent = searchBox

    local itemsContainer = create("ScrollingFrame", {
        Size              = UDim2.new(1, 0, 1, -38),
        Position          = UDim2.new(0, 0, 0, 38),
        BackgroundTransparency = 1,
        BorderSizePixel   = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = theme.accent,
        CanvasSize        = UDim2.new(0,0,0,0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ZIndex            = 21,
    })
    itemsContainer.Parent = listFrame
    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = itemsContainer

    local itemBtns = {}
    for i, item in ipairs(items) do
        local itemBtn = create("TextButton", {
            Text     = item,
            Size     = UDim2.new(1, 0, 0, 30),
            BackgroundTransparency = 1,
            TextColor3 = item == selected and theme.accent or Color3.fromRGB(175,175,200),
            TextXAlignment = Enum.TextXAlignment.Left,
            Font     = Enum.Font.Gotham,
            TextSize = 12,
            LayoutOrder = i,
            ZIndex   = 21,
            BorderSizePixel = 0,
        })
        create("UIPadding", { PaddingLeft = UDim.new(0, 12) }).Parent = itemBtn

        -- Selected accent bar
        local selBar = create("Frame", {
            Size             = UDim2.new(0, 3, 0.6, 0),
            Position         = UDim2.new(0, 0, 0.2, 0),
            BackgroundColor3 = theme.accent,
            BackgroundTransparency = item == selected and 0 or 1,
            BorderSizePixel  = 0,
            ZIndex           = 22,
        }, { makeCorner(2) })
        selBar.Parent = itemBtn

        itemBtn.Parent = itemsContainer
        itemBtn.MouseEnter:Connect(function() tween(itemBtn, { BackgroundTransparency = 0.9 }, 0.1); itemBtn.BackgroundColor3 = theme.accent end)
        itemBtn.MouseLeave:Connect(function() tween(itemBtn, { BackgroundTransparency = 1 }, 0.1) end)
        itemBtn.MouseButton1Click:Connect(function()
            -- clear old selection bars
            for _, b in ipairs(itemBtns) do
                b.btn.TextColor3 = Color3.fromRGB(175,175,200)
                b.bar.BackgroundTransparency = 1
            end
            selected = item; self._flags[flag] = item
            valLabel.Text = item
            itemBtn.TextColor3 = theme.accent
            selBar.BackgroundTransparency = 0
            listFrame.Visible = false; open = false
            pcall(callback, item)
        end)

        table.insert(itemBtns, { btn = itemBtn, bar = selBar, name = item })
    end

    -- Search filter
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = searchBox.Text:lower()
        for _, entry in ipairs(itemBtns) do
            entry.btn.Visible = entry.name:lower():find(q, 1, true) ~= nil
        end
    end)

    valBtn.MouseButton1Click:Connect(function()
        open = not open
        listFrame.Visible = open
        if open then searchBox.Text = "" end
    end)

    return {
        Set = function(v)
            selected = v; self._flags[flag] = v; valLabel.Text = v; pcall(callback, v)
        end,
        Get = function() return selected end,
    }
end

-- TEXTBOX
function NapoleonGUI:AddTextBox(section, opts)
    opts = opts or {}
    local flag     = opts.Flag    or opts.Name or "tb_" .. math.random(9999)
    local callback = opts.Callback or function() end

    self._flags[flag] = opts.Default or ""

    local row, theme = makeRow(section, 46)

    create("TextLabel", {
        Text     = opts.Name or "Input",
        Size     = UDim2.new(1, -16, 0, 18),
        Position = UDim2.new(0, 16, 0, 5),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(200,200,220),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 12,
    }).Parent = row

    local inputBg = create("Frame", {
        Size             = UDim2.new(1, -32, 0, 20),
        Position         = UDim2.new(0, 16, 0, 22),
        BackgroundColor3 = theme.inputBg,
        BorderSizePixel  = 0,
    }, { makeCorner(4) })
    inputBg.Parent = row
    local stroke = makeStroke(Color3.fromRGB(50,50,80), 1, 0.4)
    stroke.Parent = inputBg

    local box = create("TextBox", {
        Text              = opts.Default or "",
        PlaceholderText   = opts.Placeholder or "Input Here",
        Size              = UDim2.new(1, -10, 1, 0),
        Position          = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        TextColor3        = Color3.fromRGB(200,200,220),
        PlaceholderColor3 = Color3.fromRGB(80,80,110),
        TextXAlignment    = Enum.TextXAlignment.Left,
        Font              = Enum.Font.Gotham,
        TextSize          = 11,
        ClearTextOnFocus  = false,
        BorderSizePixel   = 0,
    })
    box.Parent = inputBg

    box.Focused:Connect(function()
        tween(stroke, { Color = theme.accent, Transparency = 0.3 }, 0.18)
    end)
    box.FocusLost:Connect(function(enter)
        tween(stroke, { Color = Color3.fromRGB(50,50,80), Transparency = 0.4 }, 0.18)
        self._flags[flag] = box.Text
        if enter then pcall(callback, box.Text) end
    end)

    return {
        Set = function(v) box.Text = v; self._flags[flag] = v end,
        Get = function() return box.Text end,
    }
end

-- ══════════════════════════════════════════════════════════════
--  THEME CHANGER
-- ══════════════════════════════════════════════════════════════
function NapoleonGUI:SetTheme(name)
    local t = THEMES[name]
    if not t then return end
    self.themeName = name
    self.theme = t
    tween(self._main, { BackgroundColor3 = t.body }, 0.3)
    tween(self._sidebar, { BackgroundColor3 = t.sidebar }, 0.3)
    self._logoSlash.TextColor3 = t.accent
    if self._bigN then tween(self._bigN, { TextColor3 = t.accent }, 0.3) end
    if self._gradLeft then
        tween(self._gradLeft,   { BackgroundColor3 = t.body }, 0.3)
        tween(self._gradBottom, { BackgroundColor3 = t.body }, 0.3)
        tween(self._gradTop,    { BackgroundColor3 = t.body }, 0.3)
    end
end

