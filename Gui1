    local state  = def

    create("TextLabel",{
        Text=opts.Name or "Toggle", Size=UDim2.new(0.72,0,1,0),
        Position=UDim2.new(0,14,0,0), BackgroundTransparency=1,
        TextColor3=hex(T.text), TextXAlignment=Enum.TextXAlignment.Left,
        Font=Enum.Font.Gotham, TextSize=12,
    }).Parent = row

    local track = create("TextButton",{
        Text="", Size=UDim2.new(0,40,0,20),
