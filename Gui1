-- DROPDOWN
function NapoleonGUI:AddDropdown(section, opts)
    opts = opts or {}
    local flag     = opts.Flag    or opts.Name or "dd_" .. math.random(9999)
    local items    = opts.Items   or {}
    local default  = opts.Default or (items[1] or "")
    local callback = opts.Callback or function() end

    self._flags[flag] = default

    local row, theme = makeRow(section, 36)
    local selected   = default
    local open       = false

    create("TextLabel", {
        Text     = opts.Name or "Dropdown",
        Size     = UDim2.new(0.5, 0, 1, 0),
        Position = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(208,208,232),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font     = Enum.Font.Gotham,
        TextSize = 12,
    }).Parent = row

    local valBtn = create("TextButton", {
        Text     = selected .. "  ▾",
        Size     = UDim2.new(0, 130, 0, 24),
        Position = UDim2.new(1, -144, 0.5, -12),
        BackgroundColor3 = Color3.fromRGB(15,15,30),
        TextColor3 = Color3.fromRGB(150,150,180),
        Font     = Enum.Font.Gotham,
        TextSize = 11,
        BorderSizePixel = 0,
    }, { makeCorner(4), makeStroke(theme.accent, 1, 0.72) })
    valBtn.Parent = row

    -- Dropdown list (rendered in page-level frame so it overlaps rows)
    local listFrame = create("Frame", {
        Size     = UDim2.new(0, 130, 0, math.min(#items, 5) * 28),
        Position = UDim2.new(1, -144, 0, 36),
        BackgroundColor3 = Color3.fromRGB(10,10,22),
        BorderSizePixel = 0,
        ZIndex   = 20,
        Visible  = false,
    }, { makeCorner(5), makeStroke(theme.accent, 1, 0.65) })
    listFrame.Parent = row

    create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }).Parent = listFrame

    for i, item in ipairs(items) do
        local itemBtn = create("TextButton", {
            Text     = item,
            Size     = UDim2.new(1, 0, 0, 28),
            BackgroundTransparency = 1,
            TextColor3 = item == selected and theme.accent or Color3.fromRGB(140,140,165),
            Font     = Enum.Font.Gotham,
            TextSize = 12,
            LayoutOrder = i,
            ZIndex   = 21,
            BorderSizePixel = 0,
        })
        itemBtn.Parent = listFrame
        itemBtn.MouseEnter:Connect(function()
            tween(itemBtn, { BackgroundTransparency = 0.88 }, 0.1)
        end)
        itemBtn.MouseLeave:Connect(function()
            tween(itemBtn, { BackgroundTransparency = 1 }, 0.1)
        end)
        itemBtn.MouseButton1Click:Connect(function()
            selected = item
            self._flags[flag] = item
            valBtn.Text = item .. "  ▾"
            listFrame.Visible = false
            open = false
            pcall(callback, item)
        end)
    end

    valBtn.MouseButton1Click:Connect(function()
        open = not open
        listFrame.Visible = open
    end)

    return {
        Set = function(v)
            selected = v
            self._flags[flag] = v
            valBtn.Text = v .. "  ▾"
            pcall(callback, v)
        end,
        Get = function() return selected end,
    }
end

