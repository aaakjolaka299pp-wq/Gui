--  TAB  (sidebar button + page)
-- ══════════════════════════════════════════════════════════════
function NapoleonGUI:AddTab(name)
    local T  = self.theme
    local idx = #self._tabs + 1

    local btn = create("TextButton",{
        Text="", Size=UDim2.new(1,0,0,38),
        BackgroundTransparency=1, BorderSizePixel=0,
        LayoutOrder=idx,
    })
    btn.Parent = self._tabList

    -- Left accent bar
    local ind = create("Frame",{
        Size=UDim2.new(0,3,0.6,0), Position=UDim2.new(0,0,0.2,0),
        BackgroundColor3=hex(T.accent), BackgroundTransparency=1,
        BorderSizePixel=0,
    },{corner(2)})
    ind.Parent = btn

    local lbl = create("TextLabel",{
        Text=name, Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,18,0,0),
        BackgroundTransparency=1, TextColor3=Color3.fromRGB(70,70,95),
        TextXAlignment=Enum.TextXAlignment.Left,
        Font=Enum.Font.Gotham, TextSize=13,
    })
    lbl.Parent = btn

    local page = create("ScrollingFrame",{
        Name="Page_"..name, Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1, BorderSizePixel=0,
        ScrollBarThickness=3, ScrollBarImageColor3=hex(T.accent),
        CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y, Visible=false,
    })
    page.Parent = self._content
    list().Parent = page

    local tab = {name=name,btn=btn,ind=ind,lbl=lbl,page=page,_sections={},_gui=self}
    setmetatable(tab,{__index=NapoleonGUI})
    tab._flags = self._flags
    table.insert(self._tabs, tab)

    btn.MouseEnter:Connect(function()
        if self._activeTab~=tab then tween(lbl,{TextColor3=Color3.fromRGB(160,160,190)},0.1) end
    end)
    btn.MouseLeave:Connect(function()
        if self._activeTab~=tab then tween(lbl,{TextColor3=Color3.fromRGB(70,70,95)},0.1) end
    end)
    btn.MouseButton1Click:Connect(function() self:_selectTab(tab) end)
    if idx==1 then self:_selectTab(tab) end
    return tab
end

function NapoleonGUI:_selectTab(tab)
    local T = self.theme
    if self._activeTab then
        local o=self._activeTab
        tween(o.ind,{BackgroundTransparency=1},0.15)
        tween(o.lbl,{TextColor3=Color3.fromRGB(70,70,95)},0.15)
        o.lbl.Font=Enum.Font.Gotham
        o.btn.BackgroundTransparency=1
        o.page.Visible=false
    end
    self._activeTab=tab
    tween(tab.ind,{BackgroundTransparency=0},0.15)
    tween(tab.lbl,{TextColor3=hex(T.accent)},0.15)
    tab.lbl.Font=Enum.Font.GothamBold
    tab.btn.BackgroundColor3=hex(T.accent)
    tab.btn.BackgroundTransparency=0.92
    tab.page.Visible=true
end

