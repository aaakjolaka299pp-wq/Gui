            self._flags[flag] = v
            tween(track, { BackgroundColor3 = v and theme.accent or Color3.fromRGB(30,30,48) }, 0.15)
            tween(knob,  { Position = v and UDim2.new(0,25,0.5,-7) or UDim2.new(0,4,0.5,-7) }, 0.15)
