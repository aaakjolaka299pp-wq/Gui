function NapoleonGUI:AddDualButton(sec, o1, o2)
    o1=o1 or{}; o2=o2 or{}
    local T=sec._gui.theme
    sec._order=sec._order+1
    local row=create("Frame",{Size=UDim2.new(1,0,0,38),BackgroundTransparency=1,BorderSizePixel=0,LayoutOrder=sec._order})
    row.Parent=sec.body
    -- bottom sep
    create("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0.95,BorderSizePixel=0}).Parent=row
    -- mid divider
    create("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(0.5,0,0,0),BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0.93,BorderSizePixel=0}).Parent=row

    local function half(name,xScale,xOff,cb)
        local bg=create("Frame",{
            Size=UDim2.new(0.5,-1,1,-1), Position=UDim2.new(xScale,xOff,0,0),
            BackgroundColor3=hex(T.rowBg), BorderSizePixel=0,
        })
        bg.Parent=row
        mouseIcon(bg,T)
        local b=create("TextButton",{
            Text=name, Size=UDim2.new(1,-30,1,0), Position=UDim2.new(0,0,0,0),
            BackgroundTransparency=1, TextColor3=hex(T.text),
            TextXAlignment=Enum.TextXAlignment.Left,
            Font=Enum.Font.Gotham, TextSize=12, BorderSizePixel=0,
        })
        pad(12).Parent=b; b.Parent=bg
        b.MouseEnter:Connect(function() tween(bg,{BackgroundColor3=hex(T.rowHover)},0.1) end)
        b.MouseLeave:Connect(function() tween(bg,{BackgroundColor3=hex(T.rowBg)},0.1) end)
        b.MouseButton1Click:Connect(function() pcall(cb or function()end) end)
        return b
    end
    half(o1.Name or "Button 1", 0, 0, o1.Callback)
    half(o2.Name or "Button 2", 0.5, 1, o2.Callback)
end

