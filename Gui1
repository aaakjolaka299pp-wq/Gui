-- ══════════════════════════════════════════════════════════════
function NapoleonGUI:AddTab(name)
    local theme    = self.theme
    local tabIndex = #self._tabs + 1

    -- Sidebar button
    local btn = create("TextButton", {
        Text            = "",
        Size            = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder     = tabIndex,
    })
    btn.Parent = self._tabList

    local indicator = create("Frame", {
        Size     = UDim2.new(0, 2.5, 0.7, 0),
        Position = UDim2.new(0, 0, 0.15, 0),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
    }, { makeCorner(2) })
    indicator.Parent = btn

    local dot = create("Frame", {
        Size     = UDim2.new(0, 4, 0, 4),
        Position = UDim2.new(0, 14, 0.5, -2),
        BackgroundColor3 = theme.accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
    }, { makeCorner(99) })
    dot.Parent = btn

    local label = create("TextLabel", {
        Text      = name,
        Size      = UDim2.new(1, -26, 1, 0),
        Position  = UDim2.new(0, 24, 0, 0),
        BackgroundTransparency = 1,
        TextColor3 = Color3.fromRGB(85, 85, 106),
        TextXAlignment = Enum.TextXAlignment.Left,
        Font      = Enum.Font.Gotham,
        TextSize  = 13,
    })
    label.Parent = btn

    -- Content page
    local page = create("ScrollingFrame", {
        Name            = "Page_" .. name,
        Size            = UDim2.new(1, 0, 1, 0),
        Position        = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = theme.accent,
        CanvasSize      = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible         = false,
    })
    page.Parent = self._content

    create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 0),
    }).Parent = page

    local tab = {
        name      = name,
        btn       = btn,
        indicator = indicator,
        dot       = dot,
        label     = label,
        page      = page,
        _sections = {},
        _gui      = self,
    }
    setmetatable(tab, { __index = NapoleonGUI })
    tab._flags = self._flags

    table.insert(self._tabs, tab)

    -- Hover
    btn.MouseEnter:Connect(function()
        if self._activeTab ~= tab then
            tween(label, { TextColor3 = Color3.fromRGB(180, 180, 200) }, 0.12)
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activeTab ~= tab then
            tween(label, { TextColor3 = Color3.fromRGB(85, 85, 106) }, 0.12)
        end
    end)

    btn.MouseButton1Click:Connect(function()
        self:_selectTab(tab)
    end)

    if tabIndex == 1 then
        self:_selectTab(tab)
    end

    return tab
end

function NapoleonGUI:_selectTab(tab)
    -- Deactivate old
    if self._activeTab then
        local old = self._activeTab
        tween(old.indicator, { BackgroundTransparency = 1 }, 0.15)
        tween(old.dot,       { BackgroundTransparency = 1 }, 0.15)
        tween(old.label,     { TextColor3 = Color3.fromRGB(85,85,106) }, 0.15)
        old.btn.BackgroundTransparency = 1
        old.page.Visible = false
    end
    self._activeTab = tab
    -- Activate
    tween(tab.indicator, { BackgroundTransparency = 0 }, 0.15)
    tween(tab.dot,       { BackgroundTransparency = 0 }, 0.15)
    tween(tab.label, { TextColor3 = Color3.fromRGB(255,255,255) }, 0.15)
    tab.btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    tab.btn.BackgroundTransparency = 0.93
    tab.page.Visible = true
end

