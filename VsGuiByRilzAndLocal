-- Theme Application
----------------------------------------------------------------------

-- Registry of all live theme-sensitive instances
-- Each entry: { inst, prop, key } where key maps to Theme[key]
local _themeListeners = {}
local function trackTheme(inst, prop, key)
    table.insert(_themeListeners, {inst=inst, prop=prop, key=key})
    inst[prop] = Theme[key]
    return inst
end

-- Apply current Theme globally to all tracked instances
local function applyThemeAll()
    for _, entry in ipairs(_themeListeners) do
        local ok = pcall(function() entry.inst[entry.prop] = Theme[entry.key] end)
    end
end

function UILib:SetTheme(name, window)
    local raw = THEMES[name]
    if not raw then return end
    local newTheme = buildTheme(raw)
    for k, v in pairs(newTheme) do Theme[k] = v end
    UILib.Theme = Theme
    applyThemeAll()
    -- Update status bar color
    if window and window._statusBar then
        window._statusBar.BackgroundColor3 = Theme.StatusBar
    end
end

----------------------------------------------------------------------
-- Transparency
----------------------------------------------------------------------
local _transparencyTargets = {} -- { inst, baseTransp }

local function regTransp(inst, baseTrans)
    table.insert(_transparencyTargets, {inst=inst, base=baseTrans or 0})
    return inst
end

function UILib:SetTransparency(alpha, window)
    -- alpha: 0 = opaque, 1 = fully transparent
    alpha = math.clamp(alpha or 0, 0, 0.95)
    for _, entry in ipairs(_transparencyTargets) do
        local target = math.min(entry.base + alpha, 1)
        pcall(function()
            entry.inst.BackgroundTransparency = target
        end)
    end
    if window then
        window._currentTransparency = alpha
    end
end

