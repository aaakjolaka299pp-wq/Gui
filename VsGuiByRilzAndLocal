-- Build a Color3-based Theme table from a raw hex theme entry
local function buildTheme(raw)
    local accent = H(raw.accent)
    -- Darken accent slightly for hover/dim uses
    local function dimAccent(factor)
        return Color3.new(
            math.clamp(accent.R * factor, 0, 1),
            math.clamp(accent.G * factor, 0, 1),
            math.clamp(accent.B * factor, 0, 1)
        )
    end
    return {
        Editor      = H(raw.body),
        SideBar     = H(raw.sidebar),
        ActivityBar = H(raw.bar),
        TitleBar    = H(raw.bar),
        StatusBar   = accent,
        Accent      = accent,
        AccentDim   = dimAccent(0.7),
        SectionBg   = H(raw.sectionBg),
        RowBg       = H(raw.rowBg),
        Input       = H(raw.inputBg),
        Hover       = H(raw.rowHover),
        Selected    = H(raw.rowHover),
        Border      = Color3.new(
            math.clamp(H(raw.body).R + 0.08, 0, 1),
            math.clamp(H(raw.body).G + 0.08, 0, 1),
            math.clamp(H(raw.body).B + 0.12, 0, 1)
        ),
        Text        = H(raw.text),
        TextDim     = H(raw.subtext),
        TextBright  = Color3.fromRGB(255, 255, 255),
        Success     = Color3.fromRGB(80, 200, 120),
        Warning     = Color3.fromRGB(229, 192, 123),
        Error       = Color3.fromRGB(244, 100, 90),
    }
end

